{
  "version": "2026-02-20",
  "definition_of_done": {
    "cycle_target_reviewed_count": 24,
    "require_same_product": true,
    "require_new_and_in_stock": true,
    "require_liquidity_signal": true,
    "require_profit_positive": true
  },
  "run_thresholds": {
    "min_profit_usd": 0.01,
    "min_margin_rate": 0.03,
    "min_match_score": 0.75,
    "min_ev90_usd": 0.0
  },
  "stage_a_defaults": {
    "query_page_unlock_enabled": true,
    "query_page_unlock_hours_default": 24,
    "query_page_unlock_min_pages": 1,
    "fallback_on_page_unlock_wait": true,
    "fallback_max_categories": 8
  },
  "stage_b_defaults": {
    "api_max_calls_per_run": 8,
    "multi_sku_strict": true
  },
  "env_requirements": {
    "ITEM_CONDITION": "new",
    "LIQUIDITY_REQUIRE_SIGNAL": "1",
    "AUTO_MINER_REQUIRE_LIQUIDITY_SIGNAL": "1",
    "LIQUIDITY_PROVIDER_MODE_allowed": [
      "rpa_json",
      "ebay_marketplace_insights"
    ]
  }
}

# Rakuten
RAKUTEN_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAKUTEN_APPLICATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RAKUTEN_AFFILIATE_ID=xxxxxxxx.xxxxxxxx.xxxxxxxx.xxxxxxxx

# Yahoo Shopping
YAHOO_CLIENT_ID=your_yahoo_app_id
YAHOO_APP_ID=your_yahoo_app_id

# eBay (Production)
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# Runtime defaults
TARGET_MARKETPLACE=EBAY_US
TARGET_CATEGORY=watch_new
ITEM_CONDITION=new
DEFAULT_QUERY="seiko watch"
DB_PATH=/absolute/path/to/ebayminer/data/reseller.db
# sqlite | postgres (auto: postgres when SUPABASE_DB_URL is set)
DB_BACKEND=sqlite
API_HOST=127.0.0.1
API_PORT=8000

# Supabase (Big-bang migration target)
SUPABASE_URL=https://vtspugzncsxmurzlhfyg.supabase.co
# Settings > Database > Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.vtspugzncsxmurzlhfyg.supabase.co:5432/postgres
# optional explicit override
# DB_BACKEND=postgres

# Conservative request rates for validation
EBAY_RATE_LIMIT_RPS=2
YAHOO_RATE_LIMIT_RPS=1
RAKUTEN_RATE_LIMIT_RPS=1
